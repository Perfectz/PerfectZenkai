{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,

    /* Path mapping */
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },

    /* Node types */
    "types": [
      "node",
      "vite/client",
      "vitest/globals",
      "@testing-library/jest-dom"
    ]
  },
  "include": ["src"],
  "exclude": [
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/__tests__/**",
    "src/modules/ai-chat/index.ts",
    "src/modules/ai-chat/debug-chat.ts",
    "src/modules/ai-chat/components/**",
    "src/modules/ai-chat/services/AiChatService.ts",
    "src/modules/ai-chat/services/ContextBuilder.ts",
    "src/modules/ai-chat/services/FunctionRegistry.ts",
    "src/modules/ai-chat/services/manifestFunctionBridge.ts",
    "src/modules/ai-chat/types/langchain.types.ts",
    "src/modules/daily-journal/components/ReflectionForm.tsx",
    "src/modules/workout/services/FitnessCoachingEngine.ts",
    "src/modules/workout/services/FitnessProgressEngine.ts",
    "src/modules/workout/services/WorkoutPlanningEngine.ts",
    "src/modules/workout/services/WorkoutFitnessAgent.ts"
  ],
  "references": [{ "path": "./tsconfig.node.json" }]
}
